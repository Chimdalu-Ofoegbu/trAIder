# ── trAIder frontend — local env ─────────────────────────────────────────────
# Copy to .env.local and fill in. NEXT_PUBLIC_* vars are exposed to the browser.

# Reliable Arbitrum Sepolia RPC for judge-facing LIVE on-chain reads.
# Create an "Arbitrum Sepolia" app at https://dashboard.alchemy.com and paste the
# HTTPS URL here. (Infura or any provider works too — paste the full https URL.)
# If unset, the app falls back to the public RPC (fine for dev, flaky for a demo).
NEXT_PUBLIC_ARBITRUM_SEPOLIA_RPC_URL=https://arb-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# WalletConnect Cloud project id (optional — MetaMask/Coinbase work without it).
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id
