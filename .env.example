# =============================================================================
# trAIder — environment variable schema (NO REAL VALUES — schema only)
#
# Four-key topology (D-16): each key lives in its own gitignored file.
# Copy this file to the relevant .env.* and fill in real values out-of-band.
# Real keys go in: .env.deployer | .env.operator-trade | .env.operator-journal | .env.gas
# ALL of these files are gitignored. NEVER commit a file with a real private key.
# =============================================================================

# ── Deployer key (D-16 / D-17) ──────────────────────────────────────────────
# Used by: Foundry deploy scripts, SessionFactory
# Generate: cast wallet new
DEPLOYER_PRIVATE_KEY=

# ── Operator trade key (D-16 / D-17) ────────────────────────────────────────
# Used by: orchestrator — submits GMX / MockPerps orders on behalf of each vault
# Generate: cast wallet new (independent of deployer; BIP-32 derivation rejected per D-17)
OPERATOR_TRADE_PRIVATE_KEY=

# ── Operator journal key (D-16 / D-17) ──────────────────────────────────────
# Used by: JournalPublisher — signs IPFS CID + tradeHash for JournalRegistry.recordJournal
# Generate: cast wallet new (independent EOA)
OPERATOR_JOURNAL_PRIVATE_KEY=

# ── Gas key (D-16 / D-17) ───────────────────────────────────────────────────
# Used by: keeper / gas-subsidy bot for arbitrage primitive and settlement
# Generate: cast wallet new
GAS_PRIVATE_KEY=

# ── Arbitrum RPC (D-34 / D-39 / user_setup) ─────────────────────────────────
# Source: Alchemy dashboard → Create App → Arbitrum One → HTTPS archive URL
# Required for: anvil fork tests, fork Foundry profile, GMX V2 integration
# NOTE: This is a USER SETUP item — create an Alchemy account and provision the key
ARB_RPC=

# ── Pinned fork block (D-39) ─────────────────────────────────────────────────
# Pinned Arbitrum One block: 353000000 (pinned 2026-06-01)
# Bump rule: ONLY bump when an upstream contract you depend on is upgraded.
# Every bump must be a single-commit changelog entry in git log.
# Rationale: a stable fork block makes all fork-profile tests deterministic and
# reproducible, avoids re-downloading chain state on every `make up`.
FORK_BLOCK=353000000

# ── Perps venue selector (D-04) ─────────────────────────────────────────────
# Controls which IPerpsAdapter implementation SessionFactory wires at deploy time.
# Values: mock | gmx
# Phase 0-3: mock (MockPerps.sol — deterministic, no testnet dependency)
# Phase 3+ (GMX integration): gmx (GMXAdapter.sol — real ExchangeRouter calls)
PERPS_VENUE=mock

# ── LLM API keys (Phase 2 — NOT needed for Phase 0 mock harness) ────────────
# Uncomment and fill in when Phase 2 orchestrator lands (D-14: Phase 0 is fixture-replay only).
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_AI_API_KEY=

# ── IPFS / Pinata (Phase 3 — JournalPublisher) ───────────────────────────────
# PINATA_JWT=
# WEB3_STORAGE_KEY=

# ── Postgres connection ───────────────────────────────────────────────────────
# Used by: orchestrator + backend services (via asyncpg / SQLAlchemy async)
# Default dev stack: docker-compose brings up postgres:16 on localhost:5432
DATABASE_URL=postgresql+asyncpg://traider:traider@localhost:5432/traider

# ── Redis connection ──────────────────────────────────────────────────────────
# Used by: backend WebSocket pub/sub (redis.asyncio)
REDIS_URL=redis://localhost:6379

# ── Robinhood Chain testnet (Phase 6 / D-71) ────────────────────────────────
# Chain ID 46630, RPC from Alchemy (Robinhood's official RPC provider)
# ROBINHOOD_RPC=https://rpc.testnet.chain.robinhood.com
