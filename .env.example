# =============================================================================
# trAIder — environment variable schema (NO REAL VALUES — schema only)
#
# Four-key topology (D-16): each key lives in its own gitignored file.
# Copy this file to the relevant .env.* and fill in real values out-of-band.
# Real keys go in: .env.deployer | .env.operator-trade | .env.operator-journal | .env.gas
# ALL of these files are gitignored. NEVER commit a file with a real private key.
# =============================================================================

# ── Deployer key (D-16 / D-17) ──────────────────────────────────────────────
# Used by: Foundry deploy scripts, SessionFactory
# Generate: cast wallet new
DEPLOYER_PRIVATE_KEY=

# ── Operator trade key (D-16 / D-17) ────────────────────────────────────────
# Used by: orchestrator — submits GMX / MockPerps orders on behalf of each vault
# Generate: cast wallet new (independent of deployer; BIP-32 derivation rejected per D-17)
OPERATOR_TRADE_PRIVATE_KEY=

# ── Operator journal key (D-16 / D-17) ──────────────────────────────────────
# Used by: JournalPublisher — signs IPFS CID + tradeHash for JournalRegistry.recordJournal
# Generate: cast wallet new (independent EOA)
OPERATOR_JOURNAL_PRIVATE_KEY=

# ── Gas key (D-16 / D-17) ───────────────────────────────────────────────────
# Used by: keeper / gas-subsidy bot for arbitrage primitive and settlement
# Generate: cast wallet new
GAS_PRIVATE_KEY=

# ── ARB_KEY4 — house-arb bot EOA (Phase 4 / D-08/D-09/D-10) ─────────────────
# Used by: gate/run_gate.py + orchestrator/loop/arb_bot.py
# The arb bot fires arbCloseGap on all 3 pools to keep mTOKEN/USDC AMM price pegged
# to vault NAV. KEY #4 is ARB-ONLY — it is NEVER shared with the operator-trade EOA.
# Compromise of key #4 is not a capital-drain vector: arbCloseGap is permissionless.
# Funding: ≥0.05 ETH (gas) + ≥500 mock USDC (arbMint working capital) on Sepolia.
# Generate: cast wallet new
ARB_KEY4_PRIVATE_KEY=
ARB_KEY4_ADDRESS=

# ── OPERATOR_LP_KEY — liquidity-provider EOA for the 3 Camelot V3 pools (Phase 4 / D-06) ──
# Used by: gate/run_gate.py, gate/preflight.py, harness step 3 (remove LP) + step 4 (redeem mTOKEN)
# This key provides the initial LP seed liquidity to the 3 mTOKEN/USDC pools and is the
# mmAddress registered in each mTokenVault. It redeems LP at settlement end (D-18 step 4).
# SECURITY: this key CANNOT withdraw vault USDC directly (hard-coded in mTokenVault).
# Funding: ≥0.05 ETH for gas (NPM decreaseLiquidity + collect calls).
# Generate: cast wallet new
OPERATOR_LP_KEY_PRIVATE_KEY=
OPERATOR_LP_KEY=

# ── Demo-holder wallets (Phase 4 / D-19 gate choreography) — OPTIONAL ─────────
# Used by: gate/preflight.py HOLDER_USDC check + gate/harness.py genuine_holder_buy
# Each holder executes a real mTOKEN buy via the Camelot V3 AMM before settlement.
# The gate harness reads their ACTUAL post-buy mTOKEN balance for claim assertion (D-19).
# Leave unset to skip the HOLDER_USDC pre-flight check.
# Funding: ≥10 mock USDC each (cast send <MockUSDC> "mint(address,uint256)" ... on Sepolia).
# Generate: cast wallet new
# HOLDER_CLAUDE_KEY=
# HOLDER_GPT_KEY=
# HOLDER_GEM_KEY=

# ── Arbitrum RPC (D-34 / D-39 / user_setup) ─────────────────────────────────
# Source: Alchemy dashboard → Create App → Arbitrum One → HTTPS archive URL
# Required for: anvil fork tests, fork Foundry profile, GMX V2 integration
# NOTE: This is a USER SETUP item — create an Alchemy account and provision the key
ARB_RPC=

# ── Arbitrum Sepolia RPC (DEPLOY-01 / D-14 / user_setup) ─────────────────────
# Source: Alchemy dashboard → Create App → Arbitrum Sepolia → HTTPS URL
# Required for: make deploy-sepolia, TEST-03 mini-session on Arbitrum Sepolia
# Chain ID: 421614
SEPOLIA_RPC=

# ── Arbiscan API key (DEPLOY-01 / D-14 / user_setup) ────────────────────────
# Source: https://arbiscan.io/apis → free tier is sufficient for hackathon
# Required for: make deploy-sepolia --verify auto-submits source to Arbiscan
# Scoped to: Arbitrum One + Arbitrum Sepolia (same API key works for both)
ARBISCAN_API_KEY=

# ── Operator EOA addresses (public keys — NOT private keys!) ──────────────────
# These are the PUBLIC ADDRESSES corresponding to the private keys above.
# Used by: deploy script to configure JournalRegistry + SessionFactory + vault
# OPERATOR_JOURNAL_KEY: becomes immutable in JournalRegistry (ecrecover gate, D-10)
# ORCHESTRATOR: vault.openLong/openShort/closePosition only-orchestrator gate
# OPERATOR: operator EOA (funds session; cannot withdraw vault USDC directly)
OPERATOR_JOURNAL_KEY=
ORCHESTRATOR=
OPERATOR=

# ── Pinned fork block (D-39) ─────────────────────────────────────────────────
# Pinned Arbitrum One block: 353000000 (pinned 2026-06-01)
# Bump rule: ONLY bump when an upstream contract you depend on is upgraded.
# Every bump must be a single-commit changelog entry in git log.
# Rationale: a stable fork block makes all fork-profile tests deterministic and
# reproducible, avoids re-downloading chain state on every `make up`.
FORK_BLOCK=353000000

# ── Perps venue selector (D-04) ─────────────────────────────────────────────
# Controls which IPerpsAdapter implementation SessionFactory wires at deploy time.
# Values: mock | gmx
# Phase 0-3: mock (MockPerps.sol — deterministic, no testnet dependency)
# Phase 3+ (GMX integration): gmx (GMXAdapter.sol — real ExchangeRouter calls)
PERPS_VENUE=mock

# ── LLM API keys (Phase 2 — NOT needed for Phase 0 mock harness) ────────────
# Uncomment and fill in when Phase 2 orchestrator lands (D-14: Phase 0 is fixture-replay only).
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_API_KEY=

# ── IPFS / Pinata (Phase 3 — JournalPublisher) ───────────────────────────────
# PINATA_JWT=
# WEB3_STORAGE_KEY=

# ── Postgres connection ───────────────────────────────────────────────────────
# Used by: orchestrator + backend services (via asyncpg / SQLAlchemy async)
# Default dev stack: docker-compose brings up postgres:16 on localhost:5432
DATABASE_URL=postgresql+asyncpg://traider:traider@localhost:5432/traider

# ── Redis connection ──────────────────────────────────────────────────────────
# Used by: backend WebSocket pub/sub (redis.asyncio)
REDIS_URL=redis://localhost:6379

# ── Robinhood Chain testnet (Phase 6 / D-71) ────────────────────────────────
# Chain ID 46630, RPC from Alchemy (Robinhood's official RPC provider)
# ROBINHOOD_RPC=https://rpc.testnet.chain.robinhood.com
